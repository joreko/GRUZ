{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gruz Installer",
  "version": "0.0.1",
  "identifier": "dev.gruz.installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Установка Груза",
        "width": 860,
        "height": 480,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "center": true
      }
    ],
    "security": { "csp": "default-src 'self'; script-src 'self'" }
  },
  "bundle": {
    "active": false,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
