{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for Gruz",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    {
      "identifier": "fs:default",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$TEMP/**" }
      ],
      "deny": [
        { "path": "$APPDATA/**/*.exe" },
        { "path": "$DOWNLOAD/**/*.exe" },
        { "path": "$APPDATA/**/*.bat" },
        { "path": "$DOWNLOAD/**/*.bat" },
        { "path": "$APPDATA/**/*.cmd" },
        { "path": "$DOWNLOAD/**/*.cmd" },
        { "path": "$APPDATA/**/*.dll" },
        { "path": "$DOWNLOAD/**/*.dll" },
        { "path": "$APPDATA/**/*.scr" },
        { "path": "$DOWNLOAD/**/*.scr" },
        { "path": "$APPDATA/**/*.ps1" },
        { "path": "$DOWNLOAD/**/*.ps1" },
        { "path": "$APPDATA/**/*.vbs" },
        { "path": "$DOWNLOAD/**/*.vbs" },
        { "path": "$APPDATA/**/*.msi" },
        { "path": "$DOWNLOAD/**/*.msi" }
      ]
    },
    "opener:default",
    "notification:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text"
  ]
}
