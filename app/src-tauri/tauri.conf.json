{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Груз",
  "version": "0.0.1",
  "identifier": "dev.gruz.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Груз",
        "width": 1200,
        "height": 890,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https://i.ytimg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://api.github.com https://gist.githubusercontent.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../yt-dlp.exe": "yt-dlp.exe",
      "../ffmpeg.exe": "ffmpeg.exe"
    }
  }
}
